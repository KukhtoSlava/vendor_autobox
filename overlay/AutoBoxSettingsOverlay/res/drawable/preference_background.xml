<?xml version="1.0" encoding="utf-8"?>
<!--
    Overrides Settings' preference_background drawable.
    Theme.Settings sets preferenceBackgroundColor → @drawable/preference_background,
    which is applied as the background of each preference item.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fill — adapts to light/dark via @color/autobox_pref_bg -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/autobox_pref_bg" />
        </shape>
    </item>

    <!-- Border stroke — adapts to light/dark via @color/autobox_border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="@dimen/autobox_border_width"
                android:color="@color/autobox_border" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
